# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=openemr_ts

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=change-me-in-production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
PORT=3000
NODE_ENV=development

# File Storage
UPLOAD_DIR=./uploads

# Encryption (AES-256-GCM for PHI fields like SSN)
ENCRYPTION_KEY=change-me-32-bytes-hex-encoded-key
