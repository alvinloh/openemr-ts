<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: #333; line-height: 1.5; }
    .header { border-bottom: 2px solid #2c3e50; padding-bottom: 10px; margin-bottom: 20px; display: flex; justify-content: space-between; }
    .header h1 { color: #2c3e50; margin: 0; font-size: 20px; }
    .header .subtitle { color: #7f8c8d; font-size: 11px; }
    .section { margin-bottom: 20px; }
    .section h2 { font-size: 14px; color: #2c3e50; border-bottom: 1px solid #eee; padding-bottom: 4px; margin-bottom: 8px; }
    .patient-info { background: #f8f9fa; padding: 12px; border-radius: 4px; margin-bottom: 16px; }
    .patient-info .name { font-size: 18px; font-weight: 700; }
    .patient-info .detail { color: #555; font-size: 11px; margin-top: 4px; }
    table { width: 100%; border-collapse: collapse; margin: 8px 0; }
    th, td { padding: 6px 10px; text-align: left; border-bottom: 1px solid #eee; }
    th { background: #f8f9fa; font-weight: 600; font-size: 11px; text-transform: uppercase; color: #555; }
    .vitals-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .vital-box { background: #f8f9fa; padding: 10px; border-radius: 4px; text-align: center; }
    .vital-box .value { font-size: 18px; font-weight: 700; color: #2c3e50; }
    .vital-box .label { font-size: 10px; color: #888; text-transform: uppercase; }
    .footer { border-top: 1px solid #ddd; padding-top: 8px; margin-top: 30px; font-size: 9px; color: #999; text-align: center; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 600; }
    .badge-active { background: #d4edda; color: #155724; }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <h1>Encounter Summary</h1>
      <div class="subtitle">Generated: {{generatedAt}}</div>
    </div>
  </div>

  <div class="patient-info">
    <div class="name">{{patient.firstName}} {{patient.lastName}}</div>
    <div class="detail">MRN: {{patient.mrn}} &bull; DOB: {{patient.dateOfBirth}} &bull; Sex: {{patient.sex}}</div>
    {{#if patient.phoneCell}}<div class="detail">Phone: {{patient.phoneCell}} {{#if patient.email}}&bull; Email: {{patient.email}}{{/if}}</div>{{/if}}
  </div>

  <div class="section">
    <h2>Encounter Details</h2>
    <table>
      <tr><td style="width:140px;font-weight:600;">Date</td><td>{{encounter.encounterDate}}</td></tr>
      <tr><td style="font-weight:600;">Class</td><td>{{encounter.classCode}}</td></tr>
      <tr><td style="font-weight:600;">Reason for Visit</td><td>{{encounter.reasonForVisit}}</td></tr>
      <tr><td style="font-weight:600;">Status</td><td>{{encounter.status}}</td></tr>
    </table>
  </div>

  {{#if vitals}}
  <div class="section">
    <h2>Vital Signs</h2>
    <div class="vitals-grid">
      {{#if vitals.bloodPressureSystolic}}<div class="vital-box"><div class="value">{{vitals.bloodPressureSystolic}}/{{vitals.bloodPressureDiastolic}}</div><div class="label">Blood Pressure</div></div>{{/if}}
      {{#if vitals.pulse}}<div class="vital-box"><div class="value">{{vitals.pulse}}</div><div class="label">Heart Rate</div></div>{{/if}}
      {{#if vitals.temperature}}<div class="vital-box"><div class="value">{{vitals.temperature}}</div><div class="label">Temperature</div></div>{{/if}}
      {{#if vitals.oxygenSaturation}}<div class="vital-box"><div class="value">{{vitals.oxygenSaturation}}%</div><div class="label">O2 Sat</div></div>{{/if}}
      {{#if vitals.height}}<div class="vital-box"><div class="value">{{vitals.height}}</div><div class="label">Height (cm)</div></div>{{/if}}
      {{#if vitals.weight}}<div class="vital-box"><div class="value">{{vitals.weight}}</div><div class="label">Weight (kg)</div></div>{{/if}}
      {{#if vitals.respirations}}<div class="vital-box"><div class="value">{{vitals.respirations}}</div><div class="label">Respirations</div></div>{{/if}}
    </div>
  </div>
  {{/if}}

  {{#if diagnoses.length}}
  <div class="section">
    <h2>Diagnoses</h2>
    <table>
      <thead><tr><th>Code</th><th>Description</th><th>System</th><th>Primary</th></tr></thead>
      <tbody>
        {{#each diagnoses}}
        <tr><td>{{this.code}}</td><td>{{this.description}}</td><td>{{this.codeSystem}}</td><td>{{#if this.isPrimary}}Yes{{else}}No{{/if}}</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{#if medications.length}}
  <div class="section">
    <h2>Active Medications</h2>
    <table>
      <thead><tr><th>Drug</th><th>Dosage</th><th>Route</th><th>Frequency</th></tr></thead>
      <tbody>
        {{#each medications}}
        <tr><td>{{this.drugName}}</td><td>{{this.dosage}} {{this.unit}}</td><td>{{this.route}}</td><td>{{this.frequency}}</td></tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  <div class="footer">OpenEMR-TS &mdash; Electronic Health Records &mdash; CONFIDENTIAL</div>
</body>
</html>
